<Window x:Class="CyberSecurity_Bot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIMO - Cybersecurity Awareness Bot"
        Height="700" Width="420"
        MinHeight="600" MinWidth="380"
        WindowStartupLocation="CenterScreen"
        Background="#ffe0e8"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Row 0: Top header bar -->
            <RowDefinition Height="65"/>
            <!-- Row 1: Name entry panel -->
            <RowDefinition Height="Auto"/>
            <!-- Row 2: Chat messages area -->
            <RowDefinition Height="*"/>
            <!-- Row 3: Quick topic chips -->
            <RowDefinition Height="Auto"/>
            <!-- Row 4: Bottom input bar -->
            <RowDefinition Height="65"/>
        </Grid.RowDefinitions>


        <!-- ROW 0: TOP HEADER BAR -->
        <Border Grid.Row="0"
                Background="#ff2d55"
                BorderBrush="#cc0033"
                BorderThickness="0,0,0,3">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Avatar circle -->
                <Border Grid.Column="0"
                        Width="44" Height="44"
                        CornerRadius="22"
                        Background="#ff6b8a"
                        BorderBrush="White"
                        BorderThickness="2"
                        VerticalAlignment="Center">
                    <TextBlock Text="🦇"
                               FontSize="22"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Bot name and status -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0">
                    <TextBlock Text="BIMO"
                               Foreground="White"
                               FontSize="17"
                               FontWeight="Bold"
                               FontFamily="Segoe UI"/>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8"
                                 Fill="#aaff00"
                                 VerticalAlignment="Center"
                                 Margin="0,0,5,0"/>
                        <TextBlock Text="Cybersecurity Assistant • online"
                                   Foreground="#ffccd5"
                                   FontSize="11"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- User badge -->
                <Border Grid.Column="2"
                        x:Name="UserBadge"
                        Visibility="Collapsed"
                        Background="#cc0033"
                        BorderBrush="White"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10,4"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="UserBadgeText"
                               Text="👤"
                               Foreground="White"
                               FontSize="11"
                               FontFamily="Segoe UI"/>
                </Border>
            </Grid>
        </Border>


        <!-- ROW 1: NAME ENTRY PANEL -->
        <Border Grid.Row="1"
                x:Name="NamePanel"
                Background="#ffb3c1"
                BorderBrush="#ff2d55"
                BorderThickness="0,0,0,2"
                Padding="14,10">
            <StackPanel>
                <TextBlock Text="🦇 Welcome! Enter your name to begin..."
                           Foreground="#cc0033"
                           FontSize="12"
                           FontWeight="SemiBold"
                           FontFamily="Segoe UI"
                           Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="White"
                            BorderBrush="#ff6b8a"
                            BorderThickness="2"
                            CornerRadius="20"
                            Padding="12,6">
                        <TextBox x:Name="NameTextBox"
                                 Background="Transparent"
                                 Foreground="#880022"
                                 BorderThickness="0"
                                 FontSize="13"
                                 FontFamily="Segoe UI"
                                 CaretBrush="#ff2d55"
                                 KeyDown="NameTextBox_KeyDown"/>
                    </Border>

                    <!-- Start button -->
                    <Button Grid.Column="1"
                            Content="▶"
                            Width="40" Height="40"
                            Margin="8,0,0,0"
                            Cursor="Hand"
                            Click="StartButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder"
                                        Background="#ff2d55"
                                        CornerRadius="20">
                                    <TextBlock Text="▶"
                                               Foreground="White"
                                               FontSize="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Background" Value="#cc0033"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>


        <!-- ROW 2: CHAT MESSAGES AREA -->
        <Border Grid.Row="2" Background="#fff0f3">
            <ScrollViewer x:Name="ChatScroller"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="8,6">
                <StackPanel x:Name="MessagesPanel"/>
            </ScrollViewer>
        </Border>


        <!-- ROW 3: QUICK TOPIC CHIPS -->
        <Border Grid.Row="3"
                Background="#ffb3c1"
                BorderBrush="#ff2d55"
                BorderThickness="0,2,0,2"
                Padding="8,7">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal">

                    <Button Content="password" Margin="3,0" Click="TopicButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ChipBorder"
                                        Background="#ff2d55"
                                        BorderBrush="#cc0033"
                                        BorderThickness="0"
                                        CornerRadius="14"
                                        Padding="11,6">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               Foreground="White"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               FontFamily="Segoe UI"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ChipBorder" Property="Background" Value="#cc0033"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content=" phishing" Margin="3,0" Click="TopicButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ChipBorder"
                                        Background="#ff2d55" CornerRadius="14" Padding="11,6">
                                    <TextBlock Text="{TemplateBinding Content}" Foreground="White"
                                               FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ChipBorder" Property="Background" Value="#cc0033"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content=" scam" Margin="3,0" Click="TopicButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ChipBorder"
                                        Background="#ff2d55" CornerRadius="14" Padding="11,6">
                                    <TextBlock Text="{TemplateBinding Content}" Foreground="White"
                                               FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ChipBorder" Property="Background" Value="#cc0033"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content=" privacy" Margin="3,0" Click="TopicButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ChipBorder"
                                        Background="#ff2d55" CornerRadius="14" Padding="11,6">
                                    <TextBlock Text="{TemplateBinding Content}" Foreground="White"
                                               FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ChipBorder" Property="Background" Value="#cc0033"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content=" malware" Margin="3,0" Click="TopicButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ChipBorder"
                                        Background="#ff2d55" CornerRadius="14" Padding="11,6">
                                    <TextBlock Text="{TemplateBinding Content}" Foreground="White"
                                               FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ChipBorder" Property="Background" Value="#cc0033"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content=" 2fa" Margin="3,0" Click="TopicButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ChipBorder"
                                        Background="#ff2d55" CornerRadius="14" Padding="11,6">
                                    <TextBlock Text="{TemplateBinding Content}" Foreground="White"
                                               FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ChipBorder" Property="Background" Value="#cc0033"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content=" vpn" Margin="3,0" Click="TopicButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ChipBorder"
                                        Background="#ff2d55" CornerRadius="14" Padding="11,6">
                                    <TextBlock Text="{TemplateBinding Content}" Foreground="White"
                                               FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ChipBorder" Property="Background" Value="#cc0033"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content=" backup" Margin="3,0" Click="TopicButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ChipBorder"
                                        Background="#ff2d55" CornerRadius="14" Padding="11,6">
                                    <TextBlock Text="{TemplateBinding Content}" Foreground="White"
                                               FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ChipBorder" Property="Background" Value="#cc0033"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content=" help" Margin="3,0" Click="TopicButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ChipBorder"
                                        Background="#ff2d55" CornerRadius="14" Padding="11,6">
                                    <TextBlock Text="{TemplateBinding Content}" Foreground="White"
                                               FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ChipBorder" Property="Background" Value="#cc0033"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </Border>


        <!-- ROW 4: BOTTOM INPUT BAR
             ================================================ -->
        <Border Grid.Row="4"
                Background="#ffb3c1"
                BorderBrush="#ff2d55"
                BorderThickness="0,2,0,0"
                Padding="10,0">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Input pill -->
                <Border Grid.Column="0"
                        Background="White"
                        BorderBrush="#ff6b8a"
                        BorderThickness="2"
                        CornerRadius="22"
                        Padding="14,8">
                    <TextBox x:Name="UserInput"
                             Background="Transparent"
                             Foreground="#880022"
                             BorderThickness="0"
                             FontSize="13"
                             FontFamily="Segoe UI"
                             CaretBrush="#ff2d55"
                             IsEnabled="False"
                             KeyDown="UserInput_KeyDown"/>
                </Border>

                <!-- Round send button -->
                <Button Grid.Column="1"
                        x:Name="SendBtn"
                        Width="46" Height="46"
                        Margin="8,0,0,0"
                        IsEnabled="False"
                        Click="SendButton_Click"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="SendBorder"
                                    Background="#ff2d55"
                                    CornerRadius="23"
                                    Width="46" Height="46">
                                <TextBlock Text="🩸"
                                           FontSize="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="SendBorder" Property="Background" Value="#cc0033"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="SendBorder" Property="Background" Value="#ffb3c1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </Grid>
        </Border>

    </Grid>
</Window>
