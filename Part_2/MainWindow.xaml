<Window x:Class="CyberSecurity_Bot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIMO - Cybersecurity Awareness Bot"
        Height="700" Width="420"
        MinHeight="600" MinWidth="380"
        WindowStartupLocation="CenterScreen"
        Background="#3B7597"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Row 0: Top header bar -->
            <RowDefinition Height="65"/>
            <!-- Row 1: Name entry -->
            <RowDefinition Height="Auto"/>
            <!-- Row 2: Chat messages area -->
            <RowDefinition Height="*"/>
            <!-- Row 3: Quick topic chips -->
            <RowDefinition Height="Auto"/>
            <!-- Row 4: Bottom input bar -->
            <RowDefinition Height="65"/>
        </Grid.RowDefinitions>


        <!-- ROW 0: TOP HEADER BAR -->
        <Border Grid.Row="0"
                Background="#3B7597"
                BorderBrush="#6b0020"
                BorderThickness="0,0,0,2">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Avatar circle with bat emoji -->
                <Border Grid.Column="0"
                        Width="44" Height="44"
                        CornerRadius="22"
                        Background="#3B7597"
                        BorderBrush="#8b0000"
                        BorderThickness="2"
                        VerticalAlignment="Center">
                    <TextBlock Text="🦇"
                               FontSize="22"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Bot name and status -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock Text="BIMO"
                               Foreground="#ff4466"
                               FontSize="16"
                               FontWeight="Bold"
                               FontFamily="Segoe UI"/>
                    <StackPanel Orientation="Horizontal">
                        <!-- Green online dot -->
                        <Ellipse Width="8" Height="8"
                                 Fill="#44ff88"
                                 VerticalAlignment="Center"
                                 Margin="0,0,5,0"/>
                        <TextBlock Text="Cybersecurity Assistant • online"
                                   Foreground="#aa5566"
                                   FontSize="11"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- User badge (shown after name entered) -->
                <Border Grid.Column="2"
                        x:Name="UserBadge"
                        Visibility="Collapsed"
                        Background="#9FA1FF"
                        BorderBrush="#6b0020"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10,4"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="UserBadgeText"
                               Text="👤"
                               Foreground="#ff8899"
                               FontSize="11"
                               FontFamily="Segoe UI"/>
                </Border>
            </Grid>
        </Border>


        <!-- ================================================
             ROW 1: NAME ENTRY PANEL
             ================================================ -->
        <Border Grid.Row="1"
                x:Name="NamePanel"
                Background="#3B7597"
                BorderBrush="#6b0020"
                BorderThickness="0,0,0,1"
                Padding="14,10">
            <StackPanel>
                <TextBlock Text="🩸 Welcome! Enter your name to begin..."
                           Foreground="#cc3355"
                           FontSize="12"
                           FontFamily="Segoe UI"
                           Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#9FA1FF"
                            BorderBrush="#6b0020"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="12,6">
                        <TextBox x:Name="NameTextBox"
                                 Background="Transparent"
                                 Foreground="White"
                                 BorderThickness="0"
                                 FontSize="13"
                                 FontFamily="Segoe UI"
                                 CaretBrush="#ff4466"
                                 KeyDown="NameTextBox_KeyDown"/>
                    </Border>

                    <Button Grid.Column="1"
                            Content="▶"
                            Width="40" Height="40"
                            Margin="8,0,0,0"
                            Background="#8b0000"
                            Foreground="White"
                            FontSize="16"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="StartButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="20">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#cc0000"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>


        <!-- ================================================
             ROW 2: CHAT MESSAGES AREA
             (dark blood-splatter background look)
             ================================================ -->
        <Border Grid.Row="2" Background="#180006">
            <ScrollViewer x:Name="ChatScroller"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="8,6">
                <!-- All chat bubbles go in here -->
                <StackPanel x:Name="MessagesPanel"/>
            </ScrollViewer>
        </Border>


        <!-- ================================================
             ROW 3: QUICK TOPIC CHIPS
             (horizontal scroll like WhatsApp quick replies)
             ================================================ -->
        <Border Grid.Row="3"
                Background="#220008"
                BorderBrush="#6b0020"
                BorderThickness="0,1,0,1"
                Padding="8,6">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal">

                    <Button Content="🔐 password"  Margin="3,0" Click="TopicButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#3d0015" BorderBrush="#8b0000"
                                        BorderThickness="1" CornerRadius="14" Padding="10,5">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               Foreground="#ff6688" FontSize="11"
                                               FontFamily="Segoe UI"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#5c0020"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="🎣 phishing"  Margin="3,0" Click="TopicButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#3d0015" BorderBrush="#8b0000"
                                        BorderThickness="1" CornerRadius="14" Padding="10,5">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               Foreground="#ff6688" FontSize="11"
                                               FontFamily="Segoe UI"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="💸 scam"      Margin="3,0" Click="TopicButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#3d0015" BorderBrush="#8b0000"
                                        BorderThickness="1" CornerRadius="14" Padding="10,5">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               Foreground="#ff6688" FontSize="11"
                                               FontFamily="Segoe UI"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="🔒 privacy"   Margin="3,0" Click="TopicButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#3d0015" BorderBrush="#8b0000"
                                        BorderThickness="1" CornerRadius="14" Padding="10,5">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               Foreground="#ff6688" FontSize="11"
                                               FontFamily="Segoe UI"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="🦠 malware"   Margin="3,0" Click="TopicButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#3d0015" BorderBrush="#8b0000"
                                        BorderThickness="1" CornerRadius="14" Padding="10,5">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               Foreground="#ff6688" FontSize="11"
                                               FontFamily="Segoe UI"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="🛡️ 2fa"        Margin="3,0" Click="TopicButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#3d0015" BorderBrush="#8b0000"
                                        BorderThickness="1" CornerRadius="14" Padding="10,5">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               Foreground="#ff6688" FontSize="11"
                                               FontFamily="Segoe UI"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="🌐 vpn"        Margin="3,0" Click="TopicButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#3d0015" BorderBrush="#8b0000"
                                        BorderThickness="1" CornerRadius="14" Padding="10,5">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               Foreground="#ff6688" FontSize="11"
                                               FontFamily="Segoe UI"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="💾 backup"     Margin="3,0" Click="TopicButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#3d0015" BorderBrush="#8b0000"
                                        BorderThickness="1" CornerRadius="14" Padding="10,5">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               Foreground="#ff6688" FontSize="11"
                                               FontFamily="Segoe UI"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="📋 help"       Margin="3,0" Click="TopicButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#3d0015" BorderBrush="#8b0000"
                                        BorderThickness="1" CornerRadius="14" Padding="10,5">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               Foreground="#ff6688" FontSize="11"
                                               FontFamily="Segoe UI"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </Border>


        <!-- ================================================
             ROW 4: BOTTOM INPUT BAR  (like WhatsApp)
             ================================================ -->
        <Border Grid.Row="4"
                Background="#2d0010"
                BorderBrush="#6b0020"
                BorderThickness="0,2,0,0"
                Padding="10,0">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <!-- Message input -->
                    <ColumnDefinition Width="*"/>
                    <!-- Send button -->
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Input pill (rounded like WhatsApp) -->
                <Border Grid.Column="0"
                        Background="#3d0015"
                        BorderBrush="#6b0020"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="14,8">
                    <TextBox x:Name="UserInput"
                             Background="Transparent"
                             Foreground="White"
                             BorderThickness="0"
                             FontSize="13"
                             FontFamily="Segoe UI"
                             CaretBrush="#ff4466"
                             IsEnabled="False"
                             KeyDown="UserInput_KeyDown">
                        <!-- Placeholder text -->
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="Type a message..."
                                                                   Foreground="#663344"
                                                                   FontSize="13"
                                                                   FontFamily="Segoe UI"
                                                                   Margin="2,0,0,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="Text" Value="{x:Null}">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Trigger>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Border>

                <!-- Send button (round, like WhatsApp mic/send) -->
                <Button Grid.Column="1"
                        x:Name="SendBtn"
                        Content="🩸"
                        Width="46" Height="46"
                        Margin="8,0,0,0"
                        IsEnabled="False"
                        Click="SendButton_Click"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="SendBorder"
                                    Background="#8b0000"
                                    CornerRadius="23"
                                    Width="46" Height="46">
                                <TextBlock Text="{TemplateBinding Content}"
                                           FontSize="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="SendBorder" Property="Background" Value="#cc0000"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="SendBorder" Property="Background" Value="#440010"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </Grid>
        </Border>

    </Grid>
</Window>
